{
  "name": "@egoist/electron-fetch",
  "type": "module",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./renderer": {
      "types": "./dist/renderer.d.mts",
      "default": "./dist/renderer.mjs"
    },
    "./main": {
      "types": "./dist/main.d.mts",
      "default": "./dist/main.mjs"
    },
    "./preload": {
      "types": "./dist/preload.d.mts",
      "default": "./dist/preload.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --dts",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.4",
    "vite": "^8.0.1"
  },
  "peerDependencies": {
    "electron": ">=28"
  },
  "license": "MIT"
}
